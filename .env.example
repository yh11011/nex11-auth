# 用 python3 -c "import secrets; print(secrets.token_hex(32))" 生成，所有服務共用同一個值
JWT_SECRET_KEY=change-me-in-production

# JWT 過期時間（分鐘），預設 7 天
TOKEN_EXPIRE_MINUTES=10080

# SQLite 資料庫路徑
DB_PATH=auth.db

# 允許跨域的來源（逗號分隔）
AUTH_CORS_ORIGINS=http://localhost:5000,http://localhost:5173,https://cybersecurity.nex11.me,https://yh11011.github.io

# 服務 port
PORT=9000

# AI key 加密金鑰（必須！用以下命令生成：）
# python3 -c "import secrets; print(secrets.token_hex(32))"
# 這會生成 64 個十六進位字元（32 bytes），用於 AES-256-GCM 加密
AI_KEY_ENCRYPTION_SECRET=change-me-in-production
